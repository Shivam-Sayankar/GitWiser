{
  "name": "gitwiser",
  "displayName": "GitWiser",
  "description": "AI powered context and commit assistant",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:gitwiser.generateCommit",
    "onCommand:gitwiser.explainDiffChanges",
    "onCommand:gitwiser.resumeContext"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitwiser.generateCommit",
        "title": "GitWiser: Generate Commit Message"
      },
      {
        "command": "gitwiser.explainDiffChanges",
        "title": "GitWiser: Explain Staged Changes"
      },
      {
        "command": "gitwiser.resumeContext",
        "title": "GitWiser: Resume Project Context"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "dotenv": "^17.4.2"
  }
}
