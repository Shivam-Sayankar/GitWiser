{
  "name": "gitwiser",
  "displayName": "GitWiser",
  "description": "AI-powered Git assistant for commit generation, code explanation, and project context recovery.",
  "publisher": "shivam-sayankar",
  "icon": "images/gitwiser-logo.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Shivam-Sayankar/GitWiser"
  },
  "license": "MIT",
  "keywords": [
    "git",
    "ai",
    "commit",
    "gemini",
    "vscode",
    "developer-tools"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "GitWiser",
      "properties": {
        "gitwiser.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key used for GitWiser AI features."
        }
      }
    },
    "commands": [
      {
        "command": "gitwiser.refineCommit",
        "title": "GitWiser: Refine Commit Message"
      },
      {
        "command": "gitwiser.generateCommit",
        "title": "GitWiser: Generate Commit Message"
      },
      {
        "command": "gitwiser.explainDiffChanges",
        "title": "GitWiser: Explain Staged Changes"
      },
      {
        "command": "gitwiser.resumeContext",
        "title": "GitWiser: Resume Project Context"
      }
    ]
  },
  "scripts": {
    "build": "webpack",
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test",
    "vscode:prepublish": "npm run lint && npm run build"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@google/genai": "^1.51.0"
  }
}
